<UserControl
    x:Class="System.Windows.Documents.MarkdownEditor"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:System.Windows.Documents"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Border
        Margin="5"
        BorderBrush="Gray"
        BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Line Numbers  -->
                <Canvas
                    x:Name="LineNumberCanvas"
                    Grid.Column="0"
                    Background="#F5F5F5"
                    ClipToBounds="True" />

                <!--  Text Editor  -->
                <!--  Current Line Highlight  -->
                <Rectangle
                    x:Name="CurrentLineHighlight"
                    Height="20"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Fill="#20A0C5FF"
                    IsHitTestVisible="False" />

                <TextBox
                    x:Name="Editor"
                    Grid.Column="1"
                    Padding="3"
                    AcceptsReturn="True"
                    AcceptsTab="True"
                    FontFamily="Consolas"
                    FontSize="14"
                    HorizontalScrollBarVisibility="Auto"
                    Loaded="Editor_Loaded"
                    MouseDoubleClick="Editor_MouseDoubleClick"
                    SelectionChanged="Editor_SelectionChanged"
                    TextChanged="Editor_TextChanged"
                    VerticalScrollBarVisibility="Auto">
                    <TextBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Command="ApplicationCommands.Cut" Header="Ausschneiden" />
                            <MenuItem Command="ApplicationCommands.Copy" Header="Kopieren" />
                            <MenuItem Command="ApplicationCommands.Paste" Header="Einfügen" />

                            <Separator />
                            
                            <MenuItem
                                Click="InsertMarkdownInfo_Click"
                                Header="Markdown Dokument Info"
                                InputGestureText="Strg+I" />

                            <Separator />
                            
                            <MenuItem
                                Click="LoadFile_Click"
                                Header="Datei laden"
                                InputGestureText="Strg+O" />

                            <MenuItem
                                Click="SaveFile_Click"
                                Header="Datei speichern"
                                InputGestureText="Strg+S" />

                            <Separator />

                            <MenuItem
                                Click="InsertCurrentDate_Click"
                                Header="Heutiges Datum einfügen"
                                InputGestureText="Strg+D" />

                            <Separator />

                            <MenuItem
                                Click="InsertHeader_Click"
                                Header="Überschrift (1-3)"
                                InputGestureText="Strg+H"
                                Tag="#" />

                            <MenuItem
                                Click="InsertHeader_Click"
                                Header="Zitat"
                                Tag=">" />

                            <MenuItem
                                Click="WrapWithStar_Click"
                                Header="Fett"
                                InputGestureText="Strg+F"
                                Tag="*" />

                            <MenuItem
                                Click="WrapWithStar_Click"
                                Header="Italic"
                                InputGestureText="Strg+I"
                                Tag="**" />

                            <MenuItem
                                Click="WrapWithStar_Click"
                                Header="Fett + Italic"
                                InputGestureText="Strg+J"
                                Tag="***" />

                            <Separator />

                            <MenuItem
                                Click="InsertOnPosition_Click"
                                Header="URL einfügen"
                                Tag="url" />

                            <MenuItem
                                Click="InsertOnPosition_Click"
                                Header="Bild einfügen (als Datei oder URL)"
                                Tag="bildfile" />

                            <MenuItem
                                Click="InsertOnPosition_Click"
                                Header="Bild einfügen (aus WPF Resource)"
                                Tag="bildres" />

                            <MenuItem
                                Click="InsertOnPosition_Click"
                                Header="Tabelle einfügen"
                                Tag="tab" />
                        </ContextMenu>
                    </TextBox.ContextMenu>
                </TextBox>
            </Grid>

            <!--  StatusBar  -->
            <StatusBar Grid.Row="1">
                <StatusBarItem>
                    <TextBlock Text="  " />
                </StatusBarItem>

                <StatusBarItem>
                    <TextBlock x:Name="StatusCursor" />
                </StatusBarItem>

                <Separator />

                <StatusBarItem>
                    <TextBlock x:Name="StatusLines" />
                </StatusBarItem>

                <Separator />

                <StatusBarItem>
                    <TextBlock x:Name="StatusSelection" />
                </StatusBarItem>

                <Separator />

                <StatusBarItem>
                    <TextBlock x:Name="StatusUtf" />
                </StatusBarItem>

                <StatusBarItem>
                    <TextBlock x:Name="StatusFile" />
                </StatusBarItem>
            </StatusBar>
        </Grid>
    </Border>
</UserControl>
