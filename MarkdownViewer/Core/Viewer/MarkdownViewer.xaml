<UserControl
    x:Class="System.Windows.Documents.MarkdownViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:System.Windows.Documents"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Border
            Margin="5"
            BorderBrush="Gray"
            BorderThickness="1">
            <RichTextBox
                x:Name="PART_RichText"
                BorderThickness="0"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                VerticalScrollBarVisibility="Auto">
                <RichTextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="ApplicationCommands.Copy" Header="Copy" />
                        <MenuItem Command="ApplicationCommands.SelectAll" Header="Select All" />
                        <Separator />
                        <MenuItem Click="OpenFileClick" Header="Öffenen" />
                    </ContextMenu>
                </RichTextBox.ContextMenu>
            </RichTextBox>
        </Border>
    </Grid>
</UserControl>
